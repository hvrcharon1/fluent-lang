{
  "comments": {
    "lineComment": "--"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": ":\\s*$",
    "decreaseIndentPattern": "^\\s*(End (loop|while|parallel|repeat|unless|using|match|test|validate|of|when|schedule)|Otherwise|Finally)\\b"
  },
  "onEnterRules": [
    {
      "beforeText": ":\\s*$",
      "action": { "indent": "indent" }
    },
    {
      "beforeText": "^\\s*(End (loop|while|parallel|repeat|unless|using|match|test|validate|of)|Otherwise|Finally)\\b",
      "action": { "indent": "outdent" }
    }
  ],
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "folding": {
    "markers": {
      "start": ":\\s*$",
      "end": "^\\s*End\\b"
    }
  }
}
